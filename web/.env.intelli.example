# Intelli Partner integration (WhatsApp via embedded signup)
# Copy these into .env.local and fill in the values from the Intelli portal.

# --- Public (client-side) — Intelli's Meta app used by the signup popup ---
# Provided by Intelli; safe to expose.
NEXT_PUBLIC_INTELLI_FB_APP_ID=
NEXT_PUBLIC_INTELLI_FB_CONFIG_ID=

# --- Server-side (secret) ---
# Partner API base. Default is the public production edge.
#   Local dev (portal edge):   http://localhost:3000/public/v1
#   Local dev (Django direct): http://localhost:8000/api/partners
INTELLI_API_BASE=https://api.intelliconcierge.dev/v1

# Partner API key created in the Intelli portal (Dashboard → API Keys).
# Use an ik_test_ key first (sends are simulated / dry-run).
INTELLI_PARTNER_API_KEY=ik_test_xxxxxxxxxxxx

# Webhook secret from the Intelli portal (Settings → Webhook secret), used to
# verify the X-Intelli-Signature on inbound webhooks.
INTELLI_WEBHOOK_SECRET=

# In the Intelli portal, set the partner webhook_url (Settings) to:
#   https://<your-domain>/api/webhooks/intelli
